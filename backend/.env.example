# Configuración del servicio
SERVICE_NAME=leiten-intel-scraper
LOG_LEVEL=INFO

# Timeout máximo del scraping (segundos). Spec sugiere 60-90.
SCRAPING_TIMEOUT_SECONDS=75

# Modelo LLM para el extractor estructurado
# Si se usa Azure AI Foundry / Azure OpenAI, completar AZURE_*
LLM_PROVIDER=openai           # openai | azure | mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# User-Agent para Scrapy (respetuoso con sitios públicos)
SCRAPER_USER_AGENT=LeitenIntelBot/1.0 (+https://leiten.com/contacto)

# Base de datos — dejar vacío para usar SQLite local (solo dev)
# En producción Azure: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Google Maps API (enriquecimiento de empresas y búsqueda de obras)
GOOGLE_MAPS_API_KEY=

# Apollo.io API (enriquecimiento de empresas y búsqueda de contactos)
APOLLO_API_KEY=
